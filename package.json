{
  "displayName": "Homebridge Aqara FP2",
  "name": "homebridge-fp2",
  "version": "0.4.0",
  "description": "Homebridge plugin for the Aqara Presence Sensor FP2 — exposes the main occupancy sensor, light level, and per-zone occupancy via HAP-over-WiFi.",
  "license": "MIT",
  "author": "Herman de Knop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HDeKnop/homebridge-fp2.git"
  },
  "bugs": {
    "url": "https://github.com/HDeKnop/homebridge-fp2/issues"
  },
  "homepage": "https://github.com/HDeKnop/homebridge-fp2#readme",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "^22.0.0 || ^24.0.0",
    "homebridge": "^2.0.0"
  },
  "peerDependencies": {
    "homebridge": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "homebridge": {
      "optional": false
    }
  },
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "lint": "eslint src test --max-warnings=0",
    "format": "prettier --write \"./**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"./**/*.{ts,js,json,md}\"",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preversion": "npm run lint && npm test && npm run build",
    "postversion": "git push && git push --tags",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "aqara",
    "fp2",
    "presence",
    "occupancy",
    "mmwave",
    "hap"
  ],
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.0",
    "hap-controller": "^0.10.0"
  },
  "overrides": {
    "tmp": "^0.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.0",
    "homebridge": "^2.0.0",
    "prettier": "^3.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
